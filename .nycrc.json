{
    "skipFull": true,
    "checkCoverage": true,
    "all": true,
    "exclude": [
        "**/*.spec.*",
        "**/*fixture",
        "**/*.config.*",
        "**/*.ts",
        "**/.*.*",
        "**/scripts",
        "packages/putout/bin",
        "**/processor-markdown/lib/lint.js",
