{
    "rules": {
        "coverage/add-to-exclude": ["on", {
            "list": ["**/*.ts"]
        }]
    },
    "match": {
        "*.md": {
            "declare": "off",
            "putout/convert-traverse-to-scan": "off",
            "putout/apply-remove": "off",
            "putout/declare": "on"
        }
    },
    "plugins": ["putout"]
}
